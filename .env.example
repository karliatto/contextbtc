# Copy this file to `.env` and fill in your values.
# Real environment variables take precedence over anything set here.
# NEVER commit your real `.env` (it is gitignored).

# --- Nostr identity (server) ---
# 64-char hex secret key or an `nsec...` key.
# If unset, the server generates an ephemeral key on each start (testing only).
# SERVER_NOSTR_SECRET_KEY=

# --- Bitcoin Core JSON-RPC ---
BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_USER=myuser
BITCOIN_RPC_PASSWORD=mypass

# Overall HTTP request timeout for RPC calls, in seconds (default: 30).
# BITCOIN_RPC_TIMEOUT_SECS=30

# --- Allowed client public keys ---
# If unset, allow all clients.
# ALLOWED_CLIENT_PUBKEYS=
# Example: ALLOWED_CLIENT_PUBKEYS=7b94e2871f0c...bc6148d, ab12cd34ef56...9f0011



### Client .env
# CLIENT_NOSTR_SECRET_KEY=